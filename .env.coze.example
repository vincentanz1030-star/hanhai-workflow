# Coze AI 助手配置

# Coze API 地址
COZE_API_URL=https://api.coze.com

# Coze Bot ID（从Coze平台获取）
COZE_BOT_ID=your_bot_id_here

# Coze Bot Token（从Coze平台获取）
COZE_BOT_TOKEN=your_bot_token_here

# 注意：
# 1. 如果不配置 COZE_BOT_ID 和 COZE_BOT_TOKEN，系统将使用本地规则引擎
#    提供基础的预警和建议功能
# 2. 配置后，AI助手将调用Coze API提供更智能的建议和分析
# 3. 如何获取Bot ID和Token：
#    a. 访问 https://www.coze.com/
#    b. 创建或选择你的 Bot
#    c. 在 Bot 设置中找到 ID 和 Token
#    d. 将它们填写到这里
